# eichi minisite — env-var template. Copy to .env and edit.
#
# All fields are optional. The defaults are tuned for a single-user
# local dev setup behind an upstream auth gate; nothing here is
# security-sensitive.

# --- Backend paths ----------------------------------------------------

# Path to the sqlite-vec index DB inside the container.
# EICHI_DB=/home/hndrewaall/.local/share/eichi/index.db

# Bind-mounted host venv interpreter (resolves the editable .pth).
# EICHI_PYTHON=/home/hndrewaall/repos/eichi/.venv/bin/python

# --- Query knobs ------------------------------------------------------

# SEARCH_DEFAULT_K=20
# SEARCH_MAX_K=100
# SEARCH_QUERY_TIMEOUT=30

# --- Branding ---------------------------------------------------------

# SEARCH_SITE_TITLE=eichi search
# SEARCH_SITE_LOGO_URL=
# SEARCH_SITE_LOGO_DEFAULT=1
# SEARCH_SITE_BRAND=
# SEARCH_SITE_FAVICON_URL=

# --- Optional media-source deep-link bases ----------------------------

# EMBY_BASE_URL=
# NAVIDROME_BASE_URL=
# KAVITA_BASE_URL=
